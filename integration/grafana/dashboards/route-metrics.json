{
  "uid": "route-metrics",
  "title": "Route Metrics",
  "tags": ["caddy", "route_metrics", "frankenphp"],
  "editable": true,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "templating": {
    "list": [{
      "name": "instance",
      "label": "Instance",
      "type": "query",
      "datasource": "Prometheus",
      "query": "label_values(caddy_route_requests_total, instance)",
      "refresh": 2,
      "includeAll": true,
      "multi": true,
      "current": {"text": "All", "value": "$__all"}
    }]
  },
  "panels": [
    {
      "title": "Requests / sec by Route",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (route) (rate(caddy_route_requests_total{instance=~\"$instance\"}[1m]))", "legendFormat": "{{route}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}}
    },
    {
      "title": "Top Routes (total count)",
      "type": "bargauge",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "topk(15, sum by (route) (caddy_route_requests_total{instance=~\"$instance\"}))", "legendFormat": "{{route}}", "instant": true}
      ],
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "5xx Error Rate by Route",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (route) (rate(caddy_route_errors_total{instance=~\"$instance\"}[1m]))", "legendFormat": "{{route}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0, "color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "title": "p95 Latency by Route (ms)",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 20},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (route, le) (rate(caddy_route_request_duration_milliseconds_bucket{instance=~\"$instance\"}[1m])))", "legendFormat": "{{route}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "min": 0}}
    },
    {
      "title": "p50 Latency by Route (ms)",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 20},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (route, le) (rate(caddy_route_request_duration_milliseconds_bucket{instance=~\"$instance\"}[1m])))", "legendFormat": "{{route}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "min": 0}}
    },
    {
      "title": "By HTTP Method",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 30},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (method) (caddy_route_requests_total{instance=~\"$instance\"})", "legendFormat": "{{method}}", "instant": true}
      ]
    },
    {
      "title": "By Status Code",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 30},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (status_code) (caddy_route_requests_total{instance=~\"$instance\"})", "legendFormat": "{{status_code}}", "instant": true}
      ]
    },
    {
      "title": "By Instance",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 30},
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (instance) (caddy_route_requests_total)", "legendFormat": "{{instance}}", "instant": true}
      ]
    }
  ]
}
